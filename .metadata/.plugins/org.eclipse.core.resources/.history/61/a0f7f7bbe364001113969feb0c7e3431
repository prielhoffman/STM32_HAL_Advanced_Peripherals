#include "main.h"
#include <string.h>
#include <stdio.h>

/* Function prototype */
static void GPIO_Init(void);
static void UART2_Init(void);
static void SystemClock_HSE_8MHz_Config(void);
static void Print_Clock_Info(void);

/* Peripheral handles */
UART_HandleTypeDef huart2;

#define RX_BUFFER_SIZE 100

/* UART RX variables used by the interrupt callback */
uint8_t rxByte = 0;
uint8_t rxBuffer[RX_BUFFER_SIZE];
uint8_t rxIndex = 0;

int main(void){
	  HAL_Init();
	    /*
	     * Configure the system clock for this lesson:
	     * HSE = 8 MHz
	     * SYSCLK = 8 MHz
	     * HCLK = 4 MHz
	     * PCLK = 2 MHz
	     */
	  SystemClock_HSE_8MHz_Config();

	  GPIO_Init();
	  UART2_Init();

	    /* Print the clock values after the new clock configuration */
	    Print_Clock_Info();

	  if (HAL_UART_Receive_IT(&huart2, &rxByte, 1) != HAL_OK){
		  Error_Handler();
	  }

	  while (1){
		  HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);
		  HAL_Delay(500);
	  }
}

static void GPIO_Init(void){
	GPIO_InitTypeDef GPIO_InitStruct = {0};

	__HAL_RCC_GPIOA_CLK_ENABLE();

	GPIO_InitStruct.Pin = GPIO_PIN_5;
	GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;
	GPIO_InitStruct.Pull = GPIO_NOPULL;
	GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;

	HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);
}

static void UART2_Init(void){
	huart2.Instance = USART2;

	huart2.Init.BaudRate = 115200;
	huart2.Init.WordLength = UART_WORDLENGTH_8B;
	huart2.Init.StopBits = UART_STOPBITS_1;
	huart2.Init.Parity = UART_PARITY_NONE;
	huart2.Init.Mode = UART_MODE_TX_RX;
	huart2.Init.HwFlowCtl = UART_HWCONTROL_NONE;
	huart2.Init.OverSampling = UART_OVERSAMPLING_16;
	huart2.Init.OneBitSampling = UART_ONE_BIT_SAMPLE_DISABLE;
	huart2.Init.ClockPrescaler = UART_PRESCALER_DIV1;
	huart2.AdvancedInit.AdvFeatureInit = UART_ADVFEATURE_NO_INIT;

	if(HAL_UART_Init(&huart2) != HAL_OK){
		Error_Handler();
	}
}

static volatile uint8_t clock_error_stage = 0;

static void SystemClock_HSE_8MHz_Config(void)
{
    RCC_OscInitTypeDef osc_init = {0};
    RCC_ClkInitTypeDef clk_init = {0};

    /*
     * Stage 1: Configure HSE in bypass mode.
     */
    osc_init.OscillatorType = RCC_OSCILLATORTYPE_HSE;
    osc_init.HSEState = RCC_HSE_BYPASS;
    osc_init.PLL.PLLState = RCC_PLL_OFF;

    if (HAL_RCC_OscConfig(&osc_init) != HAL_OK)
    {
        clock_error_stage = 1;
        Error_Handler();
    }

    /*
     * Stage 2: Select HSE as SYSCLK and configure prescalers.
     */
    clk_init.ClockType = RCC_CLOCKTYPE_SYSCLK |
                         RCC_CLOCKTYPE_HCLK   |
                         RCC_CLOCKTYPE_PCLK1;

    clk_init.SYSCLKSource = RCC_SYSCLKSOURCE_HSE;
    clk_init.AHBCLKDivider = RCC_SYSCLK_DIV2;
    clk_init.APB1CLKDivider = RCC_HCLK_DIV2;

    if (HAL_RCC_ClockConfig(&clk_init, FLASH_LATENCY_0) != HAL_OK)
    {
        clock_error_stage = 2;
        Error_Handler();
    }

    __HAL_RCC_HSI_DISABLE();
}
static void Print_Clock_Info(void){
	char msg[100];

    /* Print SYSCLK  */
	memset(msg, 0, sizeof(msg));
	sprintf(msg, "SYSCLK: %lu Hz\r\n", HAL_RCC_GetSysClockFreq());
	HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);

    /* Print HCLK  */
	memset(msg, 0, sizeof(msg));
	sprintf(msg, "HCLK: %lu Hz\r\n", HAL_RCC_GetSysClockFreq());
	HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);

    /* Print PCLK1  */
	memset(msg, 0, sizeof(msg));
	sprintf(msg, "PCLK1: %lu Hz\r\n", HAL_RCC_GetSysClockFreq());
	HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);

}

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart){
	if (huart->Instance == USART2){
	      // If Enter was received
	      if (rxByte == '\r' || rxByte == '\n'){
	          rxBuffer[rxIndex] = '\0';

	          char newline[] = "\r\n";

	          HAL_UART_Transmit(&huart2, (uint8_t*)newline, strlen(newline), HAL_MAX_DELAY);

	          // Send the modified string back to the PC
	          HAL_UART_Transmit(&huart2, rxBuffer, rxIndex, HAL_MAX_DELAY);

	          HAL_UART_Transmit(&huart2, (uint8_t*)newline, strlen(newline), HAL_MAX_DELAY);

	          rxIndex = 0;
	      }

	      // If there is still space in the buffer
	      else if (rxIndex < RX_BUFFER_SIZE - 1){
	          if (rxByte >= 'a' && rxByte <= 'z'){
	              rxByte = rxByte - ('a' - 'A');
	          }

	          rxBuffer[rxIndex] = rxByte;
	          rxIndex++;
	      }

	      // Buffer overflow
	      else {
	    	  rxIndex = 0;

	          char overflowMsg[] = "\r\nBuffer overflow. Try a shorter string.\r\n";
	          HAL_UART_Transmit(&huart2, (uint8_t*)overflowMsg, strlen(overflowMsg), HAL_MAX_DELAY);
	      }
	      HAL_UART_Receive_IT(&huart2, &rxByte, 1);
	}
}

void Error_Handler(void)
{
    /*
     * Blink pattern:
     * clock_error_stage = 1 -> HAL_RCC_OscConfig failed
     * clock_error_stage = 2 -> HAL_RCC_ClockConfig failed
     */
    __disable_irq();

    __HAL_RCC_GPIOA_CLK_ENABLE();

    GPIO_InitTypeDef GPIO_InitStruct = {0};
    GPIO_InitStruct.Pin = GPIO_PIN_5;
    GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;
    GPIO_InitStruct.Pull = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
    HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

    while (1)
    {
        for (uint8_t i = 0; i < clock_error_stage; i++)
        {
            HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);
            for (volatile uint32_t d = 0; d < 120000; d++);

            HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);
            for (volatile uint32_t d = 0; d < 120000; d++);
        }

        /*
         * Long pause between blink groups.
         */
        for (volatile uint32_t d = 0; d < 700000; d++);
    }
}
